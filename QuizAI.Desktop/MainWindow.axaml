<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuizAI.Desktop.ViewModels"
        xmlns:views="using:QuizAI.Desktop.Views"
        x:Class="QuizAI.Desktop.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Quiz AI"
        Width="1000"
        Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#f0f3f6">

  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type vm:LoginViewModel}">
      <views:LoginView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
      <views:LibraryView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:CreateQuizViewModel}">
      <views:CreateQuizView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:TakeQuizViewModel}">
      <views:TakeQuizView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ResultViewModel}">
      <views:ResultView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
      <views:HistoryView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
      <views:ProfileView/>
    </DataTemplate>
  </Window.DataTemplates>

  <Grid RowDefinitions="Auto,*">

    <!-- Top bar (only when logged in) -->
    <Border Grid.Row="0"
            IsVisible="{Binding IsLoggedIn}"
            Background="#2c3e50" Padding="16,10">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Grid.Column="0"
                   Text="Quiz AI"
                   FontSize="18" FontWeight="Bold"
                   Foreground="White" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1"
                   Text="{Binding CurrentUserName, StringFormat='Welcome, {0}'}"
                   HorizontalAlignment="Center"
                   Foreground="#bdc3c7"
                   VerticalAlignment="Center"/>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Button Content="History"
                  Click="OnHistoryClick"
                  Background="#34495e" Foreground="White"
                  CornerRadius="6" Padding="10,5" FontSize="12"/>
          <Button Content="Profile"
                  Click="OnProfileClick"
                  Background="#34495e" Foreground="White"
                  CornerRadius="6" Padding="10,5" FontSize="12"/>
          <TextBlock Text="v1.0"
                     Foreground="#7f8c8d"
                     VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main content area -->
    <ContentControl Grid.Row="1"
                    Content="{Binding CurrentView}"/>

  </Grid>
</Window>

