# Copy this file to appsettings.Development.json and fill in your values

## Database (PostgreSQL)
ConnectionStrings__DefaultConnection=Server=localhost;Port=5432;Database=quizai;User Id=postgres;Password=YOUR_PASSWORD;SslMode=Require;

## OpenAI
OpenAI__ApiKey=sk-proj-YOUR_API_KEY

## Cloudinary
Cloudinary__CloudName=YOUR_CLOUD_NAME
Cloudinary__ApiKey=YOUR_API_KEY
Cloudinary__ApiSecret=YOUR_API_SECRET

## JWT
Jwt__Secret=YOUR_SECRET_KEY_MINIMUM_32_CHARS

## Admin Account
Admin__Email=admin@example.com
Admin__Password=YourSecurePassword123!
